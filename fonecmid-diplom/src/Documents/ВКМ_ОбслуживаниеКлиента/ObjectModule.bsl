#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область ОбработчикиСобытий

Процедура ОбработкаПроведения(Отказ, РежимПроведения)
	// Регистр ВКМ_ВыполненныеКлиентуРаботы Расход
	Движения.ВКМ_ВыполненныеКлиентуРаботы.Записывать = Истина;
	Движения.ВКМ_ВыполненныеКлиентуРаботы.Очистить();
	// Проверяем заполнение реквизитов перед запросом
	Если Не ЗначениеЗаполнено(Договор) Тогда
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = "Не выбран договор!";
		Сообщение.Сообщить();
		Возврат;
	КонецЕсли;
	// Получаем параметры договора из базы данных
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ДоговорыКонтрагентов.ВидДоговора КАК ВидДоговора,
		|	ДоговорыКонтрагентов.ВКМ_ДатаНачала КАК ДатаНачала,
		|	ДоговорыКонтрагентов.ВКМ_ДатаОкончания КАК ДатаОкончания,
		|	ДоговорыКонтрагентов.ВКМ_СтоимостьЧасаРаботы КАК СтоимостьЧаса
		|ИЗ
		|	Справочник.ДоговорыКонтрагентов КАК ДоговорыКонтрагентов
		|ГДЕ
		|	ДоговорыКонтрагентов.Ссылка = &Ссылка";
	
	Запрос.УстановитьПараметр("Ссылка", Договор);
	РезультатЗапроса = Запрос.Выполнить();
	
	Если РезультатЗапроса.Пустой() Тогда
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = "Договор не найден в системе!";
		Сообщение.Сообщить();		Возврат;	
	КонецЕсли;
	
	ВыборкаДоговор = РезультатЗапроса.Выбрать();
	ВыборкаДоговор.Следующий();
	// Проверяем тип договора
	Если ВыборкаДоговор.ВидДоговора <> Перечисления.ВидыДоговоровКонтрагентов.ВКМ_АбонентскоеОбслуживание Тогда
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = "Выбранный договор не является договором абонентского обслуживания!";		Сообщение.Сообщить();
		Возврат;	
	КонецЕсли;
	// Проверяем попадание даты документа в период действия договора
	ДатаДок = НачалоДня(Дата);
	ДатаНач = НачалоДня(ВыборкаДоговор.ДатаНачала);
	ДатаОконч = КонецДня(ВыборкаДоговор.ДатаОкончания);
	
	Если (ЗначениеЗаполнено(ДатаНач) И ДатаДок < ДатаНач) Или (ЗначениеЗаполнено(ДатаОконч) И ДатаДок > ДатаОконч) Тогда
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = "Дата документа выходит за рамки периода действия договора!";
		Сообщение.Поле = "Дата";
		Сообщение.УстановитьДанные(ЭтотОбъект);
		Сообщение.Сообщить();
		Отказ = Истина;
	КонецЕсли;

	Если Отказ Тогда
		Возврат;
	КонецЕсли;

	// Подсчитываем общее количество часов к оплате из табличной части
	ВсегоЧасовКОплате = ВыполненныеРаботы.Итог("ЧасыКОплатеКлиенту");
	
	Если ВсегоЧасовКОплате > 0 Тогда
		// Рассчитываем сумму исходя из стоимости часа в договоре
		СтоимостьЧаса = ?(ЗначениеЗаполнено(ВыборкаДоговор.СтоимостьЧаса), ВыборкаДоговор.СтоимостьЧаса, 0);
		СуммаДокумента = ВсегоЧасовКОплате * СтоимостьЧаса;
		// Формируем движение (Приход увеличивает задолженность клиента перед нами)
		Движение = Движения.ВКМ_ВыполненныеКлиентуРаботы.Добавить();
		Движение.ВидДвижения = ВидДвиженияНакопления.Приход;
		Движение.Период = Дата;
		// Заполнение измерений
		Движение.Клиент = Клиент;
		Движение.Договор = Договор;
		// Заполнение ресурсов
		Движение.КоличествоЧасов = ВсегоЧасовКОплате;
		Движение.СуммаКОплате = СуммаДокумента;
		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#КонецЕсли
