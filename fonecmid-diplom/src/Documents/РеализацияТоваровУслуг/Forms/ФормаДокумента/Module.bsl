&НаКлиенте
Процедура Подключаемый_ПродолжитьВыполнениеКомандыНаСервере(ПараметрыВыполнения, ДополнительныеПараметры) Экспорт
    ВыполнитьКомандуНаСервере(ПараметрыВыполнения);
КонецПроцедуры

&НаСервере
Процедура ВыполнитьКомандуНаСервере(ПараметрыВыполнения)
    ПодключаемыеКоманды.ВыполнитьКоманду(ЭтотОбъект, ПараметрыВыполнения, Объект);
КонецПроцедуры

&НаКлиенте
Процедура Подключаемый_ОбновитьКоманды()
    ПодключаемыеКомандыКлиентСервер.ОбновитьКоманды(ЭтотОбъект, Объект);
КонецПроцедуры
// Конец СтандартныеПодсистемы.ПодключаемыеКоманды

#КонецОбласти

#КонецОбласти
&НаКлиенте
Процедура ВКМ_Заполнить(Команда)
	
	// 1. Проверяем вид договора прямо на клиенте (через реквизит формы Объект)
	// Предполагаем, что Договор — это реквизит документа со ссылкой на Справочник.ДоговорыКонтрагентов
	Если ЗначениеЗаполнено(Объект.Договор) Тогда
		ВКМ_ЗаполнитьНаСервере();
	Иначе
		ПоказатьПредупреждение(, "Не выбран договор для заполнения!");
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ВКМ_ЗаполнитьНаСервере()
	
	// 2. Проверяем вид договора (требуется обращение к реквизиту справочника ДоговорыКонтрагентов)
	ВидДоговора = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Объект.Договор, "ВидДоговора"); // Замените "ВидДоговора" на точное имя вашего реквизита вида договора в справочнике
	
	Если ВидДоговора = Перечисления.ВидыДоговоровКонтрагентов.ВКМ_АбонентскоеОбслуживание Тогда
		
		// 3. Конвертируем данные формы в прикладной объект ДокументОбъект
		ДокументОбъект = РеквизитФормыВЗначение("Объект");
		
		// 4. Вызываем процедуру из модуля объекта
		ДокументОбъект.ВКМ_ВыполнитьАвтозаполнение();
		
		// 5. Возвращаем измененный объект обратно на форму
		ЗначениеВРеквизитФормы(ДокументОбъект, "Объект");
		
	Иначе
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = "Заполнение доступно только для договоров абонентского обслуживания!";
		Сообщение.Сообщить();
	КонецЕсли;
	
КонецПроцедуры
&НаКлиенте
Процедура ВКМ_ПечатьАкта(Команда)
	
	// Проверяем, записан ли документ. Печать незаписанного документа не имеет смысла
	Если Не ЗначениеЗаполнено(Объект.Ссылка) Тогда
		ПоказатьПредупреждение(, "Перед печатью документ необходимо записать!");
		Возврат;
	КонецЕсли;
	
	// Вызываем серверный метод для формирования табдокумента
	ТабДок = ВКМ_СформироватьАктНаСервере();
	
	// Показываем печатную форму пользователю
	ТабДок.Показать("Акт об оказанных услугах");
	
КонецПроцедуры

&НаСервере
Функция ВКМ_СформироватьАктНаСервере()
	
	// Конвертируем данные формы в объект для вызова метода печати
	ДокументОбъект = РеквизитФормыВЗначение("Объект");
	Возврат ДокументОбъект.ВКМ_ПечатьАктаОбОказанныхУслугах();
	
КонецФункции
